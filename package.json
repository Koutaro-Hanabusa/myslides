{
  "name": "mySlides",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "hono": "^4.8.2",
      "@trpc/server": "^11.5.0",
      "dotenv": "^17.2.2",
      "zod": "^4.1.11",
      "typescript": "^5.8.2",
      "tsdown": "^0.15.5",
      "wrangler": "^4.40.3",
      "@types/node": "^22.13.11",
      "@trpc/client": "^11.5.0"
    }
  },
  "type": "module",
  "scripts": {
    "check": "oxlint && oxfmt --write",
    "prepare": "lefthook install",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @mySlides/db db:push",
    "db:studio": "turbo -F @mySlides/db db:studio",
    "db:generate": "turbo -F @mySlides/db db:generate",
    "db:migrate": "turbo -F @mySlides/db db:migrate"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.13.11",
    "lefthook": "^2.0.13",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "tsdown": "^0.15.5",
    "turbo": "^2.5.4"
  },
  "packageManager": "bun@1.2.23"
}
