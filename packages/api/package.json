	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@trpc/server": "catalog:",
		"@trpc/client": "catalog:",
		"hono": "catalog:",
		"dotenv": "catalog:",
		"zod": "catalog:",
		"@mySlides/db": "workspace:*"
	}
}
